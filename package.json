{
  "name": "@uluops/ops-sdk",
  "version": "1.0.0",
  "description": "SDK for the UluOps validation tracker API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./types/enums": {
      "import": "./dist/types/enums.js",
      "types": "./dist/types/enums.d.ts"
    },
    "./types/auth": {
      "import": "./dist/types/auth.js",
      "types": "./dist/types/auth.d.ts"
    },
    "./types/projects": {
      "import": "./dist/types/projects.js",
      "types": "./dist/types/projects.d.ts"
    },
    "./types/runs": {
      "import": "./dist/types/runs.js",
      "types": "./dist/types/runs.d.ts"
    },
    "./types/issues": {
      "import": "./dist/types/issues.js",
      "types": "./dist/types/issues.d.ts"
    },
    "./types/analytics": {
      "import": "./dist/types/analytics.js",
      "types": "./dist/types/analytics.d.ts"
    },
    "./types/responses": {
      "import": "./dist/types/responses.js",
      "types": "./dist/types/responses.d.ts"
    },
    "./types/schemas": {
      "import": "./dist/types/schemas.js",
      "types": "./dist/types/schemas.d.ts"
    },
    "./errors": {
      "import": "./dist/errors/index.js",
      "types": "./dist/errors/index.d.ts"
    },
    "./config": {
      "import": "./dist/config/index.js",
      "types": "./dist/config/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "uluops",
    "validation",
    "tracker",
    "sdk",
    "api"
  ],
  "author": "Uluops <engineering@uluops.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Uluops/-uluops-ops-sdk.git"
  },
  "dependencies": {
    "@uluops/sdk-core": "^0.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "nock": "^14.0.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^3.0.4"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
